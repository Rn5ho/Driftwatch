# Copy to backend/.env — config.py loads it into the process environment.

# Read directly by the Anthropic SDK (required for the analyst):
ANTHROPIC_API_KEY=sk-ant-...

# Model cascade: triage (rejects ~90% noise) -> analysis -> escalation (only
# when a trade is near or the category is high-stakes). Cost scales with
# decisions, not event volume — roughly $1-1.5/day at typical feed volume.
DRIFTWATCH_TRIAGE_MODEL=claude-haiku-4-5
DRIFTWATCH_ANALYST_MODEL=claude-sonnet-4-6
DRIFTWATCH_ESCALATION_MODEL=claude-opus-4-8
# Fraction of analyzed events also shadow-scored by the other models (never
# traded) — feeds the /api/models Brier comparison. 0 disables.
DRIFTWATCH_SHADOW_RATE=0.15

DRIFTWATCH_STARTING_CASH=10000
DRIFTWATCH_KELLY_FRACTION=0.25
DRIFTWATCH_MAX_POSITION_FRAC=0.10
DRIFTWATCH_FEE_BPS=10
DRIFTWATCH_MIN_PROBABILITY=0.60
DRIFTWATCH_MIN_EDGE_TO_TRADE=0.05
